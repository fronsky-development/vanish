# Auto-detect text files and normalize line endings
* text=auto

# Java sources
*.java text diff=java
*.gradle text diff=java
*.properties text

# Documentation
*.md text diff=markdown
*.txt text

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf
gradlew text eol=lf
gradlew.bat text eol=crlf

# YAML
*.yml text
*.yaml text

# XML
*.xml text

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary

